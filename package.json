{
  "name": "bolao-copa-monorepo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "format:check": "prettier --check .",
    "lint": "npm run lint:check --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test:foundation",
    "test:unit": "node --test test/unit/environment.test.cjs",
    "test:coverage": "node test/run-coverage.cjs",
    "test:foundation": "docker compose up -d postgres && node --test --test-concurrency=1 test/foundation.integration.test.cjs",
    "test:foundation:ci": "node --test --test-concurrency=1 test/foundation.integration.test.cjs",
    "audit": "npm audit --audit-level=low",
    "commitlint": "commitlint",
    "validate:branch": "node scripts/validate-branch-name.cjs",
    "test:governance": "node --test test/governance.test.cjs",
    "prepare": "node .husky/install.mjs",
    "ci": "npm run format:check && npm run lint && npm run build && npm run test:governance && npm run test:coverage && npm run test:foundation && npm run audit",
    "ci:runner": "npm run format:check && npm run lint && npm run build && npm run test:governance && npm run test:coverage && npm run test:foundation:ci && npm run audit"
  },
  "lint-staged": {
    "apps/**/!(*.d).{ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --check"
    ],
    "*.{js,cjs,mjs,ts,tsx}": "prettier --check",
    "*.{json,md,yml,yaml}": "prettier --check"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.2",
    "typescript": "~5.5.2"
  },
  "overrides": {
    "multer": "1.4.5-lts.1",
    "postcss": "8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
