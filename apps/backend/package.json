{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('tsconfig.tsbuildinfo', { force: true })\"",
    "build": "nest build --tsc -- --verbose",
    "build:clean": "npm run clean && npm run build",
    "build:debug": "tsc --build --verbose",
    "start:dev": "node ../../scripts/start-backend-dev.mjs",
    "start:compiled": "node dist/main",
    "start:prod": "node dist/main",
    "start": "node dist/main",
    "typeorm": "typeorm-ts-node-commonjs -d src/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "seed": "ts-node src/seed/seed.ts",
    "lint:check": "eslint src --max-warnings=0",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/typeorm": "^11.0.3",
    "argon2": "^0.45.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.3.0",
    "pg": "^8.11.5",
    "swagger-ui-dist": "^5.32.11",
    "typeorm": "^1.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "ts-node": "^10.9.2"
  }
}
